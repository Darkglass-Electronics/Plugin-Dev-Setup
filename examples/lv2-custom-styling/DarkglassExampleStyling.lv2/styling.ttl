@prefix dgcs: <http://www.darkglass.com/lv2/ns/lv2ext/custom-styling#> .
@prefix lv2:  <http://lv2plug.in/ns/lv2core#> .

# For images:
# An image requires a path, alignment is optional as it is not always relevant
# If the image belongs to a parameter control, animation frames must be used (from min to max)
# If the image belongs to a bypass control, at least 2 animation frames are required (on is first, then off/bypassed)
# If the image belongs to a block, animation frames are optional (if present: on is first, then off/bypassed)

# For fonts:
# A font requires a path and size

<https://github.com/Darkglass-Electronics/Plugin-Dev-Setup#example-styling>
    dgcs:blockSettings [
        a dgcs:BlockSettings ;

        # The bottom-most background image
        # Can contain multiple horizontal frames for paginated scrolling,
        # in which case it must be a multiple of the screen width
        # (on Anagram this is 1424px)
        dgcs:background [
            a dgcs:Image ;
            dgcs:path <artwork/background.png> ;
        ] ;

        # The pagination dots assume a number of frames equivalent to the number of parameter pages
        # They are 1 layer above the background
        dgcs:paginationDots [
            a dgcs:Image ;
            dgcs:path <artwork/pagination-dots.png> ;
        ] ;

        # The top-bar background and buttons
        # It is 1 layer above the background
        dgcs:topBar [
            # The top-bar image cannot contain multiple frames
            dgcs:background [
                a dgcs:Image ;
                dgcs:path <artwork/top-bar.png> ;
            ] ;

            # The top-bar block name in the can either be a background image or a custom font
            # Use of background image takes precedence if both are provided
            dgcs:topBarBlockName [
                a dgcs:BlockSettingsTopBarBlockName ;
                dgcs:background [
                    a dgcs:Image ;
                    dgcs:path <artwork/block-name.png> ;
                ] ;
            ] ;

            # The settings' top-bar buttons are images without any alignment
            # These images must be the correct size or are otherwise rejected
            dgcs:topBarButtons [
                a dgcs:BlockSettingsTopBarButtons ;
                # 85x50
                dgcs:buttonBack <artwork/button-back.png> ;
                dgcs:buttonClose <artwork/button-close.png> ;
                # 50x50
                dgcs:buttonMore <artwork/button-more.png> ;
                dgcs:buttonRemove <artwork/button-remove.png> ;
                dgcs:buttonSwap <artwork/button-swap.png> ;
            ] ;

            # The the top-bar scene control can either be images or background + font
            # Use of images takes precedence if both are provided
            dgcs:topBarSceneControl [
                a dgcs:BlockSettingsTopBarSceneControl ;
                dgcs:sceneControlActiveScene [
                    a dgcs:Image ;
                    dgcs:path <artwork/background.png> ;
                ] ;
                dgcs:sceneControlAllScenes [
                    a dgcs:Image ;
                    dgcs:path <artwork/background.png> ;
                ] ;
            ] ;
        ] ;

        # Bypass control in the top-bar
        # The bypass control uses images for background, background-with-scenes and toggle-switch control
        # Additionally it has an overlay for "in use"
        # Only the control is required, everything else is optional
        dgcs:bypass [
            a dgcs:BlockSettingsBypass ;
            dgcs:background [
                a dgcs:Image ;
                dgcs:path <artwork/bypass-background.png> ;
            ] ;
            dgcs:backgroundScenes [
                a dgcs:Image ;
                dgcs:path <artwork/bypass-background-scenes.png> ;
            ] ;
            dgcs:control [
                a dgcs:Image ;
                dgcs:path <artwork/bypass-control.png> ;
            ] ;
            # TODO overlays
        ] ;

        # padding of empty slots until parameters begin
        dgcs:parameterStartPadding 3 ;

        # Default parameter widgets in case a specific parameter is not specified
        dgcs:toggle [
            a dgcs:BlockSettingsParameter ;
            dgcs:background [
                a dgcs:Image ;
                dgcs:path <artwork/parameter-background.png> ;
            ] ;
            dgcs:backgroundScenes [
                a dgcs:Image ;
                dgcs:path <artwork/parameter-background-scenes.png> ;
            ] ;
            dgcs:control [
                a dgcs:Image ;
                dgcs:path <artwork/toggle.png> ;
            ] ;
            # TODO overlays
        ] ;
    ] .
